# --- Required -------------------------------------------------------------
# Storage account connection string (Azure Portal → Storage account →
# Access keys → Connection string). Needed for listing, download, and
# generating SAS download links.
AZURE_STORAGE_CONNECTION_STRING=

# --- Optional ---------------------------------------------------------------
# Comma-separated container names to index. Leave empty to index every
# container in the account.
BLOB_CONTAINERS=

# Master key for Meilisearch. Change this before exposing anything.
MEILI_MASTER_KEY=bloblens-dev-key

# Seconds between incremental sync passes.
SYNC_INTERVAL_SECONDS=300

# Text extraction limits.
MAX_TEXT_CHARS=50000      # chars of extracted text stored per document
MAX_BLOB_MB=50            # skip text extraction for blobs larger than this

# Minutes a generated download link stays valid.
SAS_EXPIRY_MINUTES=60
